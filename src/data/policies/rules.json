      "description": "MFA unlock requires IT Helpdesk intervention",
      "recommended_escalation_team": "IT Helpdesk"
    },
    {
      "id": "pol-003",
      "action": "grant_grafana_readonly",
      "agent_can_execute": true,
      "approval_required": "none",
      "conditions": [
        "Department in Engineering, Data Engineering, or SRE",
        "Read-only dashboard access only"
      ],
      "description": "Grafana read-only access can be self-service for eligible engineering roles",
      "recommended_escalation_team": "IT Helpdesk"
    },
    {
